# Supabase — only these three are read by app code. The legacy
# Marketplace integration injected an additional 12+ SUPABASE__*
# prefixed env vars (POSTGRES_URL, POSTGRES_PASSWORD, etc.) that
# nothing in the repo references. Pruned during plan-39 phase 4.
#
# Key formats post-migration (plans 39 + 43):
#   NEXT_PUBLIC_SUPABASE_URL       — https://<project-ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  — sb_publishable_…  (browser-safe; replaces legacy anon JWT, plan 43)
#   SUPABASE_SERVICE_ROLE_KEY      — sb_secret_…       (server-only; replaces legacy service_role JWT, plan 39)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...
STRIPE_LIFETIME_PRICE_ID=price_...
# LMS — Teacher payout routing
# Comma-separated emails whose courses pay directly to the platform Stripe account (no Connect fees)
PLATFORM_TEACHER_EMAILS=

# Shopify — generates unique single-use shirt promo codes per lifetime member
# SHOPIFY_SHOP_DOMAIN: your store's .myshopify.com URL (e.g. awesomewebstore.myshopify.com)
# SHOPIFY_ADMIN_API_TOKEN: Settings → Apps → Develop apps → Admin API token (needs write_price_rules scope)
# SHOPIFY_PRICE_RULE_ID: ID from Shopify Admin URL when viewing the discount: /admin/discounts/{ID}
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_...
SHOPIFY_PRICE_RULE_ID=

# Resend — transactional email for admin messages
# Get API key at https://resend.com → API Keys
# RESEND_FROM_EMAIL must be a verified domain in Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=admin@your-domain.com

# Admin dashboard access — only this email can visit /admin
ADMIN_EMAIL=your@email.com
# Same value as ADMIN_EMAIL — needed client-side to bypass paywall for admin
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com

# Public site URL (used in Stripe redirect URLs and email links)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Umami Analytics (optional — privacy-first page & event tracking)
# Get these from your Umami dashboard: Settings → Websites → your site
# Self-hosted: set all three. UMAMI_HOST_URL enables the ad-blocker proxy (server-side only).
# Cloud: set only WEBSITE_ID. Leave SCRIPT_URL and HOST_URL blank.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
UMAMI_HOST_URL=

CLOUDINARY_API_KEY=

# --- Centenarian Coach (multi-agent / LangGraph) ---
# ANTHROPIC_API_KEY: powers the supervisor + specialist agents.
#   Get it at https://console.anthropic.com → Settings → API keys.
ANTHROPIC_API_KEY=
# COACH_LLM_MODEL: Claude model id used by every coach node. Defaults to
#   claude-sonnet-4-6 if unset.
COACH_LLM_MODEL=claude-sonnet-4-6
# LangSmith tracing is OPTIONAL — the coach runs fine without these. When
# LANGSMITH_API_KEY is set, every graph run is traced.
#   Get the key at https://smith.langchain.com → Settings → API keys.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=centenarian-coach
# GOOGLE_GEMINI_API_KEY: Gemini embeddings (gemini-embedding-001 @ 768 dims)
#   for the coach knowledge-base retrieval and the existing help/RAG chat.
#   Get it at https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=
# The coach also reuses the Supabase keys above — no new Supabase vars needed.

# --- WitUS ecosystem integration ---
# Inbox (inbound): user feedback/help/bug is mirrored to BAM's one triage
# dashboard (inbox.witus.online -> Triage). Slug "centenarian-os". Non-blocking;
# if unset, the app still stores feedback locally and just skips the mirror.
INBOX_INGEST_URL=https://inbox.witus.online/api/ingest
INBOX_SOURCE_SLUG=centenarian-os
INBOX_INGEST_SECRET=
# Outbox (outbound): social-post drafts to BAM's accounts via the WitUS Outbox
# (outbox.witus.online). Same slug. Wired via lib/sender-outbox.ts when used.
OUTBOX_INGEST_URL=https://outbox.witus.online/api/ingest
OUTBOX_SOURCE_SLUG=centenarian-os
OUTBOX_INGEST_SECRET=
OUTBOX_TRIGGER_ENABLED=true

# Learn.WitUS -> CentOS metrics deep-link handoff ("Option B", signed deep-link).
# Learn.WitUS mints a short-lived HS256 JWT with this SAME shared secret; CentOS
# verifies it at /api/auth/witus/handoff and logs the learner straight into the
# metrics module. See docs/integrations/centos-read-your-body-data.md.
#   WITUS_HANDOFF_SECRET — the shared HMAC secret. Generate >=32 random bytes
#     (e.g. `openssl rand -base64 48`) and set the IDENTICAL value in Learn.WitUS.
#     Server-only; never expose with NEXT_PUBLIC_. If unset, the route is disabled.
WITUS_HANDOFF_SECRET=
# Optional — must match the iss/aud Learn.WitUS stamps into the token. Defaults below.
WITUS_HANDOFF_ISS=learn.witus.online
WITUS_HANDOFF_AUD=centenarian-os
